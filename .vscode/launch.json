{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Main",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8080"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {}
        }
    ]
}